# Copie para .env e reinicie o Vite (npm run dev:campaign).
#
# --- Sandbox / Lightsail ---
# VITE_API_BASE_URL obrigatória (absoluta). Nginx :80 + prefixo /api. Evitar :8080 a partir do teu PC.
# Com front em localhost:5175, o Spring (perfil lightsail) precisa CORS http://localhost:* .
VITE_API_BASE_URL=http://SEU_IP/api
#
# UUID do tenant quando não há subdomínio (dev local). Em PROD deixar vazio e usar Host + public_slug no backend.
VITE_TENANT_ID=
#
# --- PROD (notas para mais tarde) ---
# VITE_API_BASE_URL=https://teu-dominio/api
# VITE_TENANT_ID=
# Build: npm run build:campaign → servir dist no Nginx (subdomínio ou /campanha/* com try_files).
# Acrescentar origem da landing em app.security.cors (allowed-origin-patterns).
