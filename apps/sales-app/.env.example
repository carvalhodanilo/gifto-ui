# Variáveis do Vite (build embute VITE_*).
# Desenvolvimento: use .env.development ou valores abaixo.
# Produção: copie .env.production.example → .env.production (não versionado).

# Local (exemplo)
# VITE_APP_URL=http://localhost:5174
# VITE_API_BASE_URL=http://localhost:8080/api
# VITE_KEYCLOAK_URL=http://localhost:8081
# VITE_KEYCLOAK_REALM=gifto
# VITE_KEYCLOAK_CLIENT_ID=voucher-platform-sales-web
#
# Produção com HTTPS (opcional): VITE_CHECK_LOGIN_IFRAME=true — ver README
