{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "@core-ui/ui": ["../../packages/ui/src"],
      "@core-ui/api-client": ["../../packages/api-client/src"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../packages/ui" }, { "path": "../../packages/api-client" }]
}
