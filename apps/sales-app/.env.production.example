# Copie para .env.production e ajuste host/IP (valores embutidos no bundle pelo Vite).
# cp .env.production.example .env.production
#
# VITE_* são públicos no JS compilado — não coloque secrets aqui.

VITE_APP_URL=http://SEU_IP_OU_DOMINIO
VITE_API_BASE_URL=http://SEU_IP_OU_DOMINIO/api
VITE_KEYCLOAK_URL=http://SEU_IP_OU_DOMINIO/auth
VITE_KEYCLOAK_REALM=gifto
VITE_KEYCLOAK_CLIENT_ID=voucher-platform-sales-web
