# Copie para .env.production e ajuste (valores embutidos no bundle pelo Vite).
# cp .env.production.example .env.production
#
# VITE_* são públicos no JS compilado — não coloque secrets aqui.
#
# Com HTTPS + domínio: use https:// em todas as URLs e veja README → "HTTPS e domínio".

VITE_APP_URL=http://3.239.44.109
VITE_API_BASE_URL=http://3.239.44.109/api
VITE_KEYCLOAK_URL=http://3.239.44.109/auth
VITE_KEYCLOAK_REALM=gifto
VITE_KEYCLOAK_CLIENT_ID=voucher-platform-sales-web

# Opcional: só com TLS (https://). Ativa iframe de sessão Keycloak (logout noutro separador).
# VITE_CHECK_LOGIN_IFRAME=true
